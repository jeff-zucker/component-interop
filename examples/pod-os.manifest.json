{
  "@context": "https://jeff-zucker.github.io/component-interop/context.jsonld",
  "@id": "",
  "@type": "Manifest",
  "name": "pod-os",
  "components": {
    "@pod-os/elements": "https://cdn.jsdelivr.net/npm/@pod-os/elements@0.41.0/dist/elements/elements.esm.js"
  },
  "objects": {
    "provides": {
      "store":      { "respondTo": "pod-os:loaded", "sendValue": "detail.os.store.internalStore" },
      "auth":       { "respondTo": "pod-os:loaded", "sendValue": "detail.authenticatedFetch" },
      "navigation": { "respondTo": "pod-os:resource-loaded", "sendValue": "detail" }
    },
    "accepts": {
      "navigation": { "onElement": "pos-resource", "applyValueTo": "uri" }
    }
  }
}
