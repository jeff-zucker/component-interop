{
  "name": "sol-components",
  "attributes": {
    "data-from-query": "sol-components/core/from-query.js",
    "data-handler": "sol-components/core/handler.js",
    "data-edit-shape": "rdf-bundle"
  },
  "objects": {
    "provides": {
      "store": {
        "service": "rdf",
        "sendValue": "store"
      },
      "auth": {
        "service": "auth",
        "sendValue": "fetch"
      },
      "navigation": {
        "respondTo": "sol-navigate",
        "sendValue": "detail.url"
      }
    },
    "consumes": {
      "store": {
        "call": "rdf.useStore",
        "module": "sol-components/core/rdf.js"
      },
      "auth": {
        "call": "adoptFetch"
      }
    },
    "accepts": {
      "navigation": {
        "onElement": "sol-query",
        "applyValueTo": "endpoint"
      }
    }
  },
  "bundles": {
    "rdf-bundle": [
      "solid-logic",
      "solid-ui",
      "sol-tree-edit",
      "sol-form",
      "sol-settings",
      "sol-components/core/edit-placements.js"
    ]
  },
  "stages": {
    "local": {
      "components": {
        "menu-from-rdf": "../../sol-components/web/menu-from-rdf.js",
        "sol-accordion": "../../sol-components/web/sol-accordion.js",
        "sol-basic": "../../sol-components/web/sol-basic.js",
        "sol-breadcrumb": "../../sol-components/web/sol-breadcrumb.js",
        "sol-button": "../../sol-components/web/sol-button.js",
        "sol-calendar": "../../sol-components/web/sol-calendar.js",
        "sol-default": "../../sol-components/web/sol-default.js",
        "sol-dropdown-button": "../../sol-components/web/sol-dropdown-button.js",
        "sol-feed": "../../sol-components/web/sol-feed.js",
        "sol-form": "../../sol-components/web/sol-form.js",
        "sol-full": "../../sol-components/web/sol-full.js",
        "sol-gallery": "../../sol-components/web/sol-gallery.js",
        "sol-include": "../../sol-components/web/sol-include.js",
        "sol-live-edit": "../../sol-components/web/sol-live-edit.js",
        "sol-login": "../../sol-components/web/sol-login.js",
        "sol-menu": "../../sol-components/web/sol-menu.js",
        "sol-modal": "../../sol-components/web/sol-modal.js",
        "sol-pod-extras": "../../sol-components/web/sol-pod-extras.js",
        "sol-pod-ops": "../../sol-components/web/sol-pod-ops.js",
        "sol-pod": "../../sol-components/web/sol-pod.js",
        "sol-query": "../../sol-components/web/sol-query.js",
        "sol-rolodex": "../../sol-components/web/sol-rolodex.js",
        "sol-search": "../../sol-components/web/sol-search.js",
        "sol-settings": "../../sol-components/web/sol-settings.js",
        "sol-solidos": "../../sol-components/web/sol-solidos.js",
        "sol-tabs": "../../sol-components/web/sol-tabs.js",
        "sol-time": "../../sol-components/web/sol-time.js",
        "sol-tree-edit": "../../sol-components/web/sol-tree-edit.js",
        "sol-wac": "../../sol-components/web/sol-wac.js",
        "sol-weather": "../../sol-components/web/sol-weather.js",
        "sol-window": "../../sol-components/web/sol-window.js"
      },
      "shared-modules": {
        "rdflib": "../../sol-components/dist/vendor/rdflib.js",
        "dompurify": "../../sol-components/dist/vendor/dompurify.js",
        "ical.js": "../../sol-components/dist/vendor/ical.js.js",
        "marked": "../../sol-components/dist/vendor/marked.js",
        "@comunica/query-sparql": "https://esm.sh/@comunica/query-sparql@5",
        "solid-ui": "../../sol-components/dist/vendor/solid-ui.js",
        "solid-logic": "../../sol-components/dist/vendor/solid-logic.js",
        "@inrupt/solid-client-authn-browser": "../../sol-components/dist/vendor/@inrupt-solid-client-authn-browser.js",
        "n3": "../../sol-components/dist/vendor/n3.js",
        "rdf-validate-shacl": "../../sol-components/dist/vendor/rdf-validate-shacl.js",
        "sol-components/core/": "../../sol-components/core/",
        "sol-components/sources/": "../../sol-components/sources/",
        "sol-components/data/": "../../sol-components/data/",
        "sol-components/": "../../sol-components/web/"
      }
    },
    "cdn": {
      "components": {
        "menu-from-rdf": "https://esm.sh/sol-components/web/menu-from-rdf.js",
        "sol-accordion": "https://esm.sh/sol-components/web/sol-accordion.js",
