{
  "name": "pod-os",
  "imports": {
    "@pod-os/elements": "https://cdn.jsdelivr.net/npm/@pod-os/elements@0.41.0/dist/elements/elements.esm.js"
  },
  "interop": {
    "provides": {
      "store":    { "event": "pod-os:loaded", "path": "detail.os.store.internalStore" },
      "auth":     { "event": "pod-os:loaded", "path": "detail.authenticatedFetch" },
      "resource": { "event": "pod-os:resource-loaded", "path": "detail" }
    },
    "accepts": {
      "resource": { "selector": "pos-resource", "attr": "uri" }
    }
  }
}
