{
  "name": "component-interop",
  "version": "0.5.0",
  "description": "A small, zero-dependency capability broker for web components — let independently-authored component libraries share a store, a session, and capabilities without importing each other.",
  "type": "module",
  "main": "component-interop.js",
  "exports": {
    ".": "./component-interop.js",
    "./component-interop.js": "./component-interop.js"
  },
  "files": [
    "component-interop.js",
    "context.jsonld",
    "ns",
    "shapes",
    "examples",
    "README.md",
    "LICENSE",
    "!**/*~",
    "!**/*.swp"
  ],
  "scripts": {
    "test": "node --test --experimental-test-coverage --test-coverage-exclude='tests/**' && npm run test:jsonld",
    "test:plain": "node --test",
    "test:browsers": "node --test tests/importmap.browser.mjs",
    "test:jsonld": "node tests/validate-jsonld-manifests.mjs"
  },
  "keywords": [
    "web-components",
    "custom-elements",
    "interop",
    "importmap",
    "manifest",
    "capability",
    "broker",
    "loader",
    "esm"
  ],
  "author": "Jeff Zucker",
  "comment": "portions built using Claude Opus 4.8",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeff-zucker/component-interop"
  },
  "devDependencies": {
    "jsonld": "^9.0.0",
    "n3": "^2.0.3",
    "playwright": "^1.60.0",
    "rdf-validate-shacl": "^0.6.5",
    "sol-components": "^2.7.0"
  }
}
