{
  "@context": {
    "@version": 1.1,
    "ci": "https://jeff-zucker.github.io/component-interop/ns#",
    "schema": "https://schema.org/",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",

    "Manifest": "ci:Manifest",
    "name": "schema:name",
    "customElements": { "@id": "rdfs:seeAlso", "@type": "@id" },

    "components":     { "@id": "ci:component",    "@container": "@index", "@index": "ci:tagName",  "@type": "@id" },
    "shared-modules": { "@id": "ci:sharedModule", "@container": "@index", "@index": "schema:name", "@type": "@id" },

    "attributes": { "@id": "ci:attribute", "@container": "@index", "@index": "schema:name" },
    "bundles":    { "@id": "ci:bundle",    "@container": "@index", "@index": "schema:name" },
    "stages":     { "@id": "ci:stage",     "@container": "@index", "@index": "schema:name" },

    "objects":  "@nest",
    "provides": { "@id": "ci:provides", "@container": "@index", "@index": "schema:name" },
    "consumes": { "@id": "ci:consumes", "@container": "@index", "@index": "schema:name" },
    "accepts":  { "@id": "ci:accepts",  "@container": "@index", "@index": "schema:name" },

    "module":       "ci:module",
    "modules":      { "@id": "ci:module", "@container": "@list" },
    "service":      "ci:service",
    "respondTo":    "ci:respondTo",
    "sendValue":    "ci:sendValue",
    "priority":     "ci:priority",
    "call":         "ci:call",
    "from":         "ci:from",
    "onElement":    "ci:onElement",
    "applyValueTo": "ci:applyValueTo",
    "transform":    "ci:transform"
  }
}
